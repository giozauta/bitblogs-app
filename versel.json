{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    }
  ],
  "build": {
    "env": {
      "VITE_SUPABASE_URL": "@SUPABASE_URL",
      "VITE_SUPABASE_ANON_KEY": "@SUPABASE_ANON_KEY"
    }
  }
}
